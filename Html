 text;\n","            -webkit-text-fill-color: transparent;\n","            background-clip: text;\n","        }\n","\n","        header nav a {\n","            color: var(--text-secondary);\n","            text-decoration: none;\n","            margin: 0 1.5rem;\n","            transition: color 0.3s ease;\n","        }\n","\n","        header nav a:hover {\n","            color: var(--primary);\n","        }\n","\n","        main {\n","            max-width: 1200px;\n","            margin: 0 auto;\n","            padding: 0 2rem;\n","        }\n","\n","        section {\n","            padding: 4rem 0;\n","            animation: fadeIn 0.6s ease-in;\n","        }\n","\n","        @keyframes fadeIn {\n","            from {\n","                opacity: 0;\n","                transform: translateY(20px);\n","            }\n","            to {\n","                opacity: 1;\n","                transform: translateY(0);\n","            }\n","        }\n","\n","        h1, h2, h3 {\n","            color: var(--text-primary);\n","            margin-bottom: 1rem;\n","        }\n","\n","        h1 {\n","            font-size: 3rem;\n","            font-weight: 700;\n","        }\n","\n","        h2 {\n","            font-size: 2rem;\n","            margin-bottom: 2rem;\n","            text-align: center;\n","        }\n","\n","        h3 {\n","            font-size: 1.3rem;\n","        }\n","\n","        .hero {\n","            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);\n","            color: white;\n","            padding: 6rem 0;\n","            text-align: center;\n","            min-height: 500px;\n","            display: flex;\n","            align-items: center;\n","            justify-content: center;\n","        }\n","\n","        .hero h1 {\n","            color: white;\n","            font-size: 4rem;\n","            margin-bottom: 1rem;\n","            animation: slideDown 0.8s ease;\n","        }\n","\n","        .hero p {\