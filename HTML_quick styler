columns: repeat(auto-fit, minmax(300px, 1fr));\n","            gap: 2rem;\n","        }}\n","\n","        .testimonial {{\n","            background: rgba(30, 41, 59, 0.8);\n","            padding: 2rem;\n","            border-left: 4px solid var(--primary);\n","            border-radius: 8px;\n","        }}\n","\n","        .testimonial p {{\n","            font-style: italic;\n","            margin-bottom: 1rem;\n","            color: var(--text-secondary);\n","        }}\n","\n","        .testimonial span {{\n","            font-weight: 600;\n","            color: var(--primary);\n","        }}\n","\n","        .pricing-grid {{\n","            display: grid;\n","            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n","            gap: 2rem;\n","        }}\n","\n","        .pricing-card {{\n","            background: rgba(30, 41, 59, 0.8);\n","            padding: 2rem;\n","            border-radius: 12px;\n","            border: 1px solid var(--border);\n","            text-align: center;\n","            transition: all 0.3s ease;\n","        }}\n","\n","        .pricing-card.featured {{\n","            border-color: var(--primary);\n","            box-shadow: 0 20px 40px rgba(0,0,0,0.3);\n","            transform: scale(1.05);\n","        }}\n","\n","        .pricing-card .price {{\n","            font-size: 2.5rem;\n","            color: var(--primary);\n","            margin: 1rem 0;\n","            font-weight: 700;\n","        }}\n","\n","        .pricing-card ul {{\n","            list-style: none;\n","            margin: 1.5rem 0;\n","            text-align: left;\n","        }}\n","\n","        .pricing-card li {{\n","            padding: 0.5rem 0;\n","            color: var(--text-secondary);\n","        }}\n","\n","        .contact {{\n","            max-width: 600px;\n","            margin: 0 auto;\n","        }}\n","\n","        .contact-form {{\n","            display: flex;\n","            flex-direction: column;\n","            